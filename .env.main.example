# Main product deployment: Web + Main mobile application.
APP_SURFACE=main
MONGO_URI=<main-database-user-connection-string>
# During the initial cutover, keep the existing shared database as Main so
# existing Main/Web users and projects continue to work.
DB_NAME=construction_ai
DATA_DIR=/app/data-main
ALLOWED_ORIGINS=https://conscout.com,https://www.conscout.com

# Must resolve from the API runtime. Use the AI container's service name only
# when both services are on the same Docker network; otherwise use a reachable
# host/IP and port (for example, http://127.0.0.1:8001 for co-located processes).
AI_SERVICE_URL=http://127.0.0.1:8001

# Add the existing Google, Firebase, SMTP, payment, and AI variables here.
# Do not set ENABLE_LEGACY_BOOTSTRAP_MIGRATION in normal deployments.
