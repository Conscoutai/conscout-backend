# Lite product deployment: Lite mobile application only.
APP_SURFACE=lite
MONGO_URI=<lite-database-user-connection-string>
DB_NAME=construction_ai_lite
DATA_DIR=/app/data-lite
# Native mobile apps do not require CORS, but add a Lite web origin here if one
# is introduced later.
ALLOWED_ORIGINS=https://lite.conscout.com

# Add the Lite product's Google, Firebase, SMTP, payment, and AI variables.
# Do not set ENABLE_LEGACY_BOOTSTRAP_MIGRATION.
